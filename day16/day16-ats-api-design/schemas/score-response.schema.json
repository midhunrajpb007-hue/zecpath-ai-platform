{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ATS Score Response",
  "type": "object",
  "required": ["score_id", "resume_id", "job_id", "ats_score"],
  "properties": {
    "score_id": {
      "type": "string",
      "description": "Unique score identifier"
    },
    "resume_id": {
      "type": "string"
    },
    "job_id": {
      "type": "string"
    },
    "ats_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "components": {
      "type": "object",
      "properties": {
        "skill_match": {"type": "number"},
        "experience_match": {"type": "number"},
        "education_match": {"type": "number"}
      }
    },
    "status": {
      "type": "string",
      "enum": ["shortlisted", "review", "rejected"]
    }
  }
}